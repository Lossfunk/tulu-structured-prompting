    {
      "id": "lesson_08",
      "category": "emotions_and_feelings",
      "title": "Emotions and Feelings",
      "difficulty": "intermediate",
      "conversations": [
        {
          "english": "How are you feeling?",
          "tulu": "Ir encha anubhava maltar?",
          "context": "asking_about_feelings"
        },
        {
          "english": "I am very happy today.",
          "tulu": "indu yAn tumba ushArullae.",
          "context": "expressing_happiness"
        },
        {
          "english": "Why are you sad?",
          "tulu": "Ir entha dukkha ullar?",
          "context": "asking_about_sadness"
        },
        {
          "english": "I am worried about my work.",
          "tulu": "yAn enkDa kelasada chinta maltond ullae.",
          "context": "expressing_worry"
        },
        {
          "english": "Don't worry, everything will be fine.",
          "tulu": "chinta maltad, ellā chandae aagodu ullae.",
          "context": "comforting_someone"
        }
      ]
    },
