          "context": "asking_about_problem"
        },
        {
          "english": "I am facing some difficulties in my business.",
          "tulu": "yAn enkDa vyāpārada kēḷa kastagalu barpodu ullae.",
          "context": "explaining_business_problems"
        },
        {
          "english": "Can you help me with this?",
          "tulu": "Ir enk help maltare?",
          "context": "requesting_help"
        },
        {
          "english": "Of course, I will do whatever I can.",
          "tulu": "and, yAn enkDa sādhyavada ellā maltae.",
          "context": "offering_help"
        }
      ]
    }
