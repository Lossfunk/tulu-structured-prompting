  "lessons": [
    {
      "id": "lesson_01",
      "category": "basic_conversations",
      "title": "Greetings and Introductions",
      "difficulty": "beginner",
      "conversations": [
        {
          "english": "Hello, how are you?",
          "tulu": "namaskAra, encha ullar?",
          "context": "formal_greeting"
        },
        {
          "english": "I am fine, thank you. And you?",
          "tulu": "yAn ushArullae, solmelu. Ir encha ullar?",
          "context": "response_to_greeting"
        },
        {
          "english": "What is your name?",
          "tulu": "IrDa hesaru entha?",
          "context": "asking_name"
        },
        {
          "english": "My name is Rajesh.",
          "tulu": "enkDa hesaru Rajesh.",
          "context": "telling_name"
        },
        {
          "english": "Nice to meet you.",
          "tulu": "IrDa sange meet malthondu chandae ullae.",
          "context": "pleasure_meeting"
        }
      ]
    },
    {
      "id": "lesson_02", 
      "category": "daily_life",
      "title": "Daily Activities",
      "difficulty": "beginner",
      "conversations": [
        {
          "english": "What time do you wake up?",
          "tulu": "Ir entha vela eddae?",
          "context": "asking_wake_up_time"
        },
        {
          "english": "I wake up at 6 AM.",
          "tulu": "yAn 6 vela eddae.",
          "context": "telling_wake_up_time"
        },
        {
          "english": "What do you do in the morning?",
          "tulu": "Ir bela entha maltade?",
          "context": "asking_morning_activities"
        },
        {
          "english": "I brush my teeth and have breakfast.",
          "tulu": "yAn dante malthae aadi nashta tinpae.",
          "context": "morning_routine"
        },
        {
          "english": "Do you go to work?",
          "tulu": "Ir kelasak pōpade?",
          "context": "asking_about_work"
        }
      ]
    },
    {
