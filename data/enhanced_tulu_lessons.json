        {
          "english": "Today is Monday.",
          "tulu": "indu somavāra ullae.",
          "context": "telling_day"
        },
        {
          "english": "When is your birthday?",
          "tulu": "IrDa janmadina yāva dina ullae?",
          "context": "asking_birthday"
        }
      ]
    },
    {
