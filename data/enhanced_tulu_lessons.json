          "tulu": "enkDa kudumbad nālku jana ullapa.",
          "context": "telling_family_size"
        },
        {
          "english": "How is your father?",
          "tulu": "IrDa appa encha ullar?",
          "context": "asking_about_father"
        },
        {
          "english": "My father is doing well.",
          "tulu": "enkDa appa chandae ullar.",
          "context": "telling_about_father"
        },
        {
          "english": "Where does your mother work?",
          "tulu": "IrDa amma enka kelasa maltar?",
          "context": "asking_about_mother_work"
        }
      ]
    },
    {
      "id": "lesson_04",
      "category": "food_and_cooking",
      "title": "Food and Meals",
      "difficulty": "intermediate",
      "conversations": [
        {
          "english": "What did you have for lunch?",
          "tulu": "Ir vanas entha tinD?",
          "context": "asking_about_lunch"
        },
        {
          "english": "I had rice and curry.",
          "tulu": "yAn akhaṛụ aadi kari tinD.",
          "context": "telling_about_lunch"
        },
        {
          "english": "Is the food tasty?",
          "tulu": "onas chandae ullae?",
          "context": "asking_about_taste"
        },
        {
          "english": "Yes, it's very delicious.",
          "tulu": "and, tumba chandae ullae.",
          "context": "praising_food"
        },
        {
          "english": "Can you cook Tulu food?",
          "tulu": "Ir Tulu onas bareyond ullar?",
          "context": "asking_about_cooking_ability"
        }
      ]
    },
    {
      "id": "lesson_05",
      "category": "shopping_and_money",
      "title": "Shopping and Money",
      "difficulty": "intermediate", 
      "conversations": [
        {
          "english": "How much does this cost?",
          "tulu": "undu erthe rupai ullae?",
          "context": "asking_price"
        },
        {
          "english": "This costs 100 rupees.",
          "tulu": "undu 100 rupai ullae.",
          "context": "telling_price"
        },
        {
          "english": "Can you reduce the price?",
          "tulu": "Ir rupai kammi maltare?",
          "context": "bargaining"
        },
        {
          "english": "I will give you 80 rupees.",
          "tulu": "yAn 80 rupai kōDae.",
          "context": "offering_price"
        },
        {
          "english": "Do you have change?",
          "tulu": "IrDa sūḍa ullae?",
          "context": "asking_for_change"
        }
      ]
    },
    {
