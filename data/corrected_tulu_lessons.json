      "usage": "asking_about_something"
    },
    {
      "english": "I don't know.",
      "tulu": "enk gottuji.",
      "usage": "expressing_ignorance"
    },
    {
      "english": "Please help me.",
      "tulu": "enk help maltare.",
      "usage": "requesting_help"
    },
    {
      "english": "Excuse me.",
