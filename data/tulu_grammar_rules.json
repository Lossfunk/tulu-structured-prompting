  "syntactic_rules": [
    {
      "pattern_name": "SOV_Structure",
      "structure": "Subject + Object + Verb",
      "description": "Tulu follows Subject-Object-Verb word order",
      "examples": [
        "yān pustaka odalāṅ (I book read)",
        "āḷụ akhaṛụ tinpōḍụ (She rice eats)",
        "nama śālekụ pōpapa (We school go)"
      ]
    },
    {
      "pattern_name": "Case_Marking",
      "structure": "Noun + Case_Marker",
      "description": "Tulu uses postpositions (case markers) instead of prepositions",
      "examples": [
        "maga + aṇụ = magaaṇụ (child + accusative)",
        "pustaka + akụ = pustakakụ (book + dative)",
        "illu + lụ = illulụ (house + locative)"
      ]
    },
    {
      "pattern_name": "Verb_Agreement",
      "structure": "Verb + Person/Number_Marker",
      "description": "Verbs must agree with the subject in person and number",
      "examples": [
        "yān pōpe (I go - 1st person singular)",
        "ī pōpade (you go - 2nd person singular)",
        "aye pōpodu (he goes - 3rd person singular)"
      ]
    },
    {
      "pattern_name": "Question_Formation",
      "structure": "Question_Word + SOV",
      "description": "Questions are formed by adding question words to SOV structure",
      "examples": [
        "ēnka pōpade? (Where do you go?)",
        "ēnụ maltade? (What do you do?)",
        "yāru barppodu? (Who comes?)"
      ]
    }
  ],
